# -----------------------------------------------------------------------------
# hiWaveTel — exemplo de ambiente (.env.example)
#
# Como usar:
#   cp .env.example .env
# Edite `.env` com valores reais; não faça commit (ver `.gitignore`).
#
# `docker/docker-compose.yml` faz `env_file: ../.env`.
# -----------------------------------------------------------------------------

# =============================================================================
# 1. Django core
# =============================================================================
DJANGO_ENV=development
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,192.168.1.65,[::1]
# DJANGO_SECRET_KEY=          # obrigatório em produção
# DJANGO_DEBUG=false

# Bootstrap superuser no Docker (docker/entrypoint.sh após migrate):
# DJANGO_SUPERUSER_USERNAME=admin
# DJANGO_SUPERUSER_EMAIL=admin@hiwavetel.local
# DJANGO_SUPERUSER_PASSWORD=change-me

# =============================================================================
# 2. Servidor HTTP
# =============================================================================
HIWAVE_PORT=8000
GUNICORN_WORKERS=2
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=120

# =============================================================================
# 3. SQLite
# =============================================================================
SQLITE_DB_PATH=/app/host/db.sqlite3
SQLITE_BUSY_TIMEOUT_SEC=30
SQLITE_INIT_WAL=true
SQLITE_SYNCHRONOUS_NORMAL=true
SQLITE_LOCKED_RETRY_COUNT=15
SQLITE_LOCKED_RETRY_BACKOFF_SEC=0.02

# =============================================================================
# 4. Logging
# =============================================================================
DJANGO_LOG_DIR=/app/logs
DJANGO_LOG_FILE=hiwavetel-api.log
APPLICATION_LOG_LEVEL=INFO

# =============================================================================
# 5. Modem hardware & ModemManager
# =============================================================================
MODEM_TTY_PRIMARY=/dev/ttyUSB2
MODEM_TTY_SECONDARY=/dev/ttyUSB3
MODEM_LTE_INTERFACE=wwan0
MODEM_STRICT_WWAN_CHECK=false
MODEM_ENUMERATION_WAIT_SEC=60
MODEM_ENABLE_WAIT_SEC=90
MODEM_REPROBE_WAIT_SEC=15
MODEM_MM_WARMUP_SEC=5
MODEM_RESCAN_INTERVAL_SEC=15
SIM_UNLOCK_TIMEOUT_SEC=60
SIM_UNLOCK_RETRIES=3
SIM_UNLOCK_RETRY_SEC=5
MODEM_MANAGER_DEBUG=false
MODEM_QMI_DEVICE=/dev/cdc-wdm0
# SKIP_MODEM_HARDWARE_CHECK=

# =============================================================================
# 6. mmcli na entrada (docker/entrypoint.sh)
# =============================================================================
MMCLI_SCAN_TRIES=1
MMCLI_SCAN_SLEEP_SEC=1

# =============================================================================
# 7. SIM (opcional)
# =============================================================================
DEVICE_PIN_CODE=
# DEVICE_PHONE_NUMBER=351912329317
SIM_PATH=/org/freedesktop/ModemManager1/SIM/0
SIM_PATH_OVERRIDES_MMCLI=false

# =============================================================================
# 8. Modem index & processos segundo plano
# =============================================================================
AUTO_DETECT_MMCLI_INDEX=true
MODEM_MMCLI_INDEX=0
RUN_SMS_WATCHER=true

# =============================================================================
# 9. Filas SMS
# =============================================================================
SMS_QUEUE_WORKERS=3
SMS_QUEUE_MAX_SIZE=1000

INBOUND_PROCESSOR_WORKERS=2
INBOUND_PROCESSOR_MAX_SIZE=500
INBOUND_PROCESSOR_RETRY_MAX=5
INBOUND_PROCESSOR_RETRY_BASE_SEC=1.0

OUTBOUND_ASYNC_ENABLED=false
OUTBOUND_PROCESSOR_WORKERS=1
OUTBOUND_PROCESSOR_MAX_SIZE=10000
OUTBOUND_OUTBOX_POLL_SEC=0.1

HIWAVETEL_QUEUE_ENABLED=false
HIWAVETEL_ROLE=api

# =============================================================================
# 10. Webhooks inbound SMS (por modem — API ou Admin)
# =============================================================================
SMS_WEBHOOK_TIMEOUT_SEC=15
SMS_WEBHOOK_RETRY_MAX=5
SMS_WEBHOOK_RETRY_BASE_SEC=1.0

# =============================================================================
# 11. Container restart API
# =============================================================================
HIWAVE_ALLOW_CONTAINER_RESTART_API=true
HIWAVE_CONTAINER_RESTART_DELAY_SEC=1.0

# =============================================================================
# 12. mmcli / watcher — timeouts e retries
# =============================================================================
MMCLI_PATH=mmcli
MMCLI_TIMEOUT=45
MMCLI_RETRY_MAX=3
MMCLI_RETRY_BACKOFF_SEC=0.5

MODEM_INTF_WAIT_RETRIES=12
MODEM_INTF_WAIT_SEC=3.0
MMCLI_SNAPSHOT_TRIES=3
MMCLI_SNAPSHOT_BACKOFF_SEC=1.25
MMCLI_EMPTY_TEXT_RETRIES=5
MMCLI_EMPTY_TEXT_BACKOFF_SEC=1.5

HIWAVE_MMCLI_HEALTH_TIMEOUT=15

# =============================================================================
# 13. Rotatividade de SMS armazenado
# =============================================================================
SMS_STORAGE_ROTATION_ENABLED=true
SMS_MAX_MESSAGES_PER_MODEM=2000
SMS_ROTATION_BATCH_SIZE=100
SMS_CLEANUP_ON_STARTUP=false

# =============================================================================
# 14. Fiabilidade inbound
# =============================================================================
MODEM_SNAPSHOT_RECOVERY_INTERVAL_SEC=300
SMS_DLQ_ENABLED=true
SMS_DLQ_DB_PATH=/app/host/dlq_sms.db
SMS_DLQ_MAX_SIZE=1000
SMS_DLQ_RETRY_INTERVAL_SEC=60
SMS_DLQ_MAX_RETRIES=10
MMCLI_EMPTY_TEXT_RETRIES=8
MMCLI_RECEIVING_MAX_WAIT_SEC=60
SMS_DEBUG_LOGGING=false

# Whitelist inbound (vazio = aceitar todos)
# SMS_INBOUND_WHITELIST=+351912345678

# =============================================================================
# 14. D-Bus
# =============================================================================
DBUS_SYSTEM_BUS_ADDRESS=unix:path=/run/dbus/system_bus_socket
