# -----------------------------------------------------------------------------
# hiWaveTel — exemplo de ambiente (.env.example)
#
# Como usar:
#   cp .env.example .env
# Edite `.env` com segredos reais; não faça commit (ver `.gitignore`).
#
# `docker/docker-compose.yml` faz `env_file: ../.env`; variáveis abaixo também são
# passadas/overrides em `environment:` onde indicado — todas são lidas pela app ou
# pelo `docker/entrypoint.sh` onde referenciadas no código-fonte.
# -----------------------------------------------------------------------------

# =============================================================================
# 0. hiDisheLink API remota (hidishelink_client.py, mqtt_config_remote.py)
# =============================================================================
# Base URL sem path `/api` — os paths são `/api/sms/device/...`.
# GET /api/sms/device/mqtt-config/ no hiWaveTel faz proxy ao hiDisheLink (esta URL + X-API-Key do pedido),
# salvo quando existe HiDishelinkDevice com api_url + api_key para esse device_id (Admin).
HIDISHELINK_API_URL=http://192.168.1.77:5201
HIDISHELINK_API_TIMEOUT_SEC=30
# TTL das sessões POST /api/sms/device/login (horas)
HIDISHELINK_SESSION_TTL_HOURS=24

# MQTT_* abaixo: tuning Django para Gateway/publicações efémeras quando não há snapshot remoto —
# não montam o JSON de GET mqtt-config (esse vem sempre do hiDisheLink).
MQTT_AUTO_RECONNECT=true
MQTT_CONNECTION_TIMEOUT=30
MQTT_RECONNECT_INITIAL_DELAY_MS=1000
MQTT_RECONNECT_MAX_DELAY_MS=30000
MQTT_RECONNECT_BACKOFF_MULTIPLIER=2
MQTT_RECONNECT_MAX_RETRIES=0
MQTT_CONNECTION_WATCHDOG_INTERVAL_MS=0
MQTT_RECONNECT_JITTER=0.2

# =============================================================================
# 1. Django core (config/settings/__init__.py, development.py, production.py)
# =============================================================================
DJANGO_ENV=development
# Alternativas aceites por __init__.py para escolher o mesmo módulo settings:
# DJANGO_CONFIGURATION=
# DJANGO_STAGE=

# Hostnames ou IPs (sem porta); separados por vírgula. Inclua o IP LAN do servidor
# (ex.: 192.168.1.65) para `runserver` ou Docker na rede local.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,192.168.1.65,[::1]
# development: opcional — sem isto usa localhost padrão
# production: obrigatório (lista sem wildcard '*')
# DJANGO_SECRET_KEY=
# Produção apenas — activar DEBUG (evitar):
# DJANGO_DEBUG=false

# Opcional — Dockerfile já define para o contentor:
# DJANGO_SETTINGS_MODULE=config.settings

# =============================================================================
# 2. Servidor HTTP (docker/entrypoint.sh → gunicorn bind)
# =============================================================================
HIWAVE_PORT=8000
GUNICORN_WORKERS=2
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=120

# =============================================================================
# 3. SQLite + concorrência (config/settings/base.py + docker/entrypoint.sh)
# =============================================================================
# Caminho dentro do contentor quando se usa Compose (bind-mount típico em /app/host):
SQLITE_DB_PATH=/app/host/db.sqlite3

SQLITE_BUSY_TIMEOUT_SEC=30
SQLITE_INIT_WAL=true
SQLITE_SYNCHRONOUS_NORMAL=true
SQLITE_LOCKED_RETRY_COUNT=15
SQLITE_LOCKED_RETRY_BACKOFF_SEC=0.02

# =============================================================================
# 4. Logging Django (config/settings/base.py)
# =============================================================================
DJANGO_LOG_DIR=/app/logs
DJANGO_LOG_FILE=hiwavetel-api.log
APPLICATION_LOG_LEVEL=INFO

# =============================================================================
# 5. Modem hardware & ModemManager (docker/entrypoint.sh + docker-compose.yml devices)
# =============================================================================
MODEM_TTY_PRIMARY=/dev/ttyUSB2
MODEM_TTY_SECONDARY=/dev/ttyUSB3
MODEM_LTE_INTERFACE=wwan0
MODEM_STRICT_WWAN_CHECK=false
MODEM_ENUMERATION_WAIT_SEC=60
MODEM_ENABLE_WAIT_SEC=45
MODEM_MANAGER_DEBUG=false
MODEM_QMI_DEVICE=/dev/cdc-wdm0

# desenvolvimento: permite arrancar sem hardware (tty presente no contentor)
# SKIP_MODEM_HARDWARE_CHECK=

# =============================================================================
# 6. mmcli na entrada — rescan inicial (docker/entrypoint.sh)
# =============================================================================
MMCLI_SCAN_TRIES=1
MMCLI_SCAN_SLEEP_SEC=1

# =============================================================================
# 7. SIM (opcional unlock) — docker/entrypoint.sh
# =============================================================================
DEVICE_PIN_CODE=
# Caminho só necessário para override dual-SIM / quando mmcli não lista o esperado:
# SIM_PATH=/org/freedesktop/ModemManager1/SIM/0
SIM_PATH_OVERRIDES_MMCLI=false

# =============================================================================
# 8. Modem index Django & processos segundo plano (entrypoint.sh + base.py MODEM_MMCLI_INDEX)
# =============================================================================
AUTO_DETECT_MMCLI_INDEX=true
MODEM_MMCLI_INDEX=0
RUN_SMS_WATCHER=true
RUN_MQTT_GATEWAY=true

# =============================================================================
# 9. Fila assíncrona de inbound SMS (apps/sms/queue_processor.py)
# =============================================================================
SMS_QUEUE_WORKERS=3
SMS_QUEUE_MAX_SIZE=1000

# =============================================================================
# 9a. Fila de processamento post-save de inbound SMS (apps/sms/inbound_processor.py)
# =============================================================================
# Número de workers para processar InboundSms após save (mirror + MQTT publish)
INBOUND_PROCESSOR_WORKERS=2
# Tamanho máximo da fila
INBOUND_PROCESSOR_MAX_SIZE=500
# Retry logic para falhas de MQTT publish
INBOUND_PROCESSOR_RETRY_MAX=5
INBOUND_PROCESSOR_RETRY_BASE_SEC=1.0

# =============================================================================
# 10. mmcli / watcher D-Bus — timeouts e retries (apps/sms/mmcli_client.py, dbus_watch.py)
# =============================================================================
MMCLI_PATH=mmcli
MMCLI_TIMEOUT=45
MMCLI_RETRY_MAX=3
MMCLI_RETRY_BACKOFF_SEC=0.5

MODEM_INTF_WAIT_RETRIES=12
MODEM_INTF_WAIT_SEC=3.0
MMCLI_SNAPSHOT_TRIES=3
MMCLI_SNAPSHOT_BACKOFF_SEC=1.25
# MultipartSMS: Messaging.Added can race antes do texto estar disponível via mmcli —
# tentativas apenas quando estado receiving/unknown ou metadatos (sender/timestamp)
# aparecem sem texto (apps/sms/services.py persist_inbound_sms)
MMCLI_EMPTY_TEXT_RETRIES=5
MMCLI_EMPTY_TEXT_BACKOFF_SEC=1.5

# =============================================================================
# 11. Sondas auxiliares (config/settings/base.py HIWAVE_MMCLI_HEALTH_TIMEOUT)
# =============================================================================
HIWAVE_MMCLI_HEALTH_TIMEOUT=15

# =============================================================================
# 12. MQTT gateway (variáveis em config/settings/base.py; consumidas via django.conf.settings)
# =============================================================================
MQTT_BROKER_URL=localhost
MQTT_PORT=1883
MQTT_USER=
MQTT_PASS=
MQTT_CLIENT_ID=hiwavetel_gateway
MQTT_KEEPALIVE=60
MQTT_QOS=1
MQTT_CLEAN_SESSION=false
MQTT_EXTERNAL_TOPIC_PREFIX=hidishelink_dev
# Catálogo/modems (MQTT_BASE_TOPIC_PREFIX). Vazio → igual a MQTT_EXTERNAL_TOPIC_PREFIX.
MQTT_BASE_TOPIC_PREFIX=
# Tópicos por dispositivo (MQTT_DEVICE_TOPIC_PREFIX). Vazio → {MQTT_BASE_TOPIC_PREFIX}/devices.
# Se usar `${MQTT_BASE_TOPIC_PREFIX}/devices`, o Django expande em config/settings/base.py (Compose não faz isto só).
MQTT_DEVICE_TOPIC_PREFIX=

MQTT_PUBLISH_SEND_REQUEST=true
# Sem override no Compose, o default em config/settings/base.py é false:
MQTT_PUBLISH_MODEM_INBOX=true
MQTT_EPHEMERAL_PUBLISH_TIMEOUT_SEC=15

MQTT_MODEM_INBOX_DELIVERY_MODE=broadcast
MQTT_MODEM_STATUS_SUBSCRIBE=true
MQTT_MODEM_STATUS_COMMAND_TIMEOUT_SEC=45
MQTT_MODEM_STATUS_AUTO_PUBLISH=true
MQTT_MODEM_STATUS_POLL_INTERVAL_SEC=30

# Opcional: subscrever catálogo gateway hiDisheLink em modems/snapshot e modems/contacts (persistência JSON).
MQTT_SUBSCRIBE_MODEM_CATALOG=true

# Subscrever o tópico health/ping (telemetria tipo A + resposta a pings tipo B). Desligar desactiva também a persistência de telemetria.
MQTT_HEALTH_PING_SUBSCRIBE=true
# Resposta automática a health/ping com ping_id ecoado para health/pong (independente da subscrição acima).
MQTT_HEALTH_AUTO_PONG=true
# QoS apenas da subscrição wildcard `{MQTT_DEVICE_TOPIC_PREFIX}/+/health/ping` (0–2; valores inválidos → 0).
MQTT_HEALTH_PING_SUBSCRIBE_QOS=0
# Subscrever `{MQTT_DEVICE_TOPIC_PREFIX}/+/health/pong` para actualizar ExternalDevice.last_seen quando a app responder ao ping Django.
MQTT_HEALTH_SUBSCRIBE_PONG=true
# Opcional/redundante na maioria dos casos: com MQTT_HEALTH_AUTO_PONG=true o gateway já publica pong
# (eco do ping_id) também para pings com source=django. Use true apenas se precisar de combinações específicas
# entre as duas flags (ver código GatewayMqttClient._handle_health_ping).
MQTT_HEALTH_GATEWAY_AUTO_PONG_DJANGO=false

# run_mqtt_gateway: pings MQTT tipo B (source=django) por cada ExternalDevice active; ≤0 desliga. Apenas com este comando activo.
MQTT_HEALTH_SERVER_PING_INTERVAL_SEC=60

# Valor por defeito devolvido em GET /api/sms/device/mqtt-config (`SMS_INBOX_ENABLED`).
SMS_INBOX_ENABLED_DEFAULT=true

# Ao publicar sms/send para o gateway: máximo de destinatários por mensagem MQTT (chunk_index/chunk_total se >1 chunk).
MQTT_SEND_RECIPIENTS_CHUNK_SIZE=50

# =============================================================================
# 12a. MQTT Remote hiDisheLink Bridge (apps/external_device/mqtt_client.py RemoteHiDishelinkClient)
# =============================================================================
# Activar modo bridge: liga ao broker remoto hiDisheLink para receber sms/send e publicar status/inbox.
# True = hiWaveTel funciona como Device/Gateway Client na arquitectura hiDisheLink (seção 10).
MQTT_REMOTE_BRIDGE_ENABLED=true

# Manter broker local para devices Android que falem diretamente com hiWaveTel (LocalGatewayClient).
MQTT_LOCAL_BROKER_ENABLED=true

# Device ID para o remote client (formato E.164, ex: +351912329317).
# Se vazio, usa o primeiro HiDishelinkDevice activo da BD ou falha se não existir.
MQTT_REMOTE_DEVICE_ID=

# Intervalo de heartbeat health/ping tipo A (telemetria sem source:django) enviado ao broker remoto (segundos).
# Valor 0 desliga. Recomendado: 60s. Checklist item 6 da seção 10.10.
MQTT_REMOTE_HEALTH_HEARTBEAT_SEC=60

# run_mqtt_gateway startup: refrescar mqtt-config do hiDisheLink REST ou usar snapshot em cache.
# false (padrão) = usa cache quando presente, evita erros de conexão ruidosos quando hiDisheLink inacessível.
# true = força refresh remoto mesmo com cache válido (comportamento anterior).
MQTT_CONFIG_STARTUP_REFRESH=false

# =============================================================================
# 12b. Rotatividade de SMS armazenado (cleanup_sms_storage)
# =============================================================================
# Master switch: desligar impede a rotação automática (comando manual ainda pode correr com --force).
SMS_STORAGE_ROTATION_ENABLED=true
# Máximo de InboxMessage e SmsRequest por ExternalDevice (cada tipo, independentemente).
SMS_MAX_MESSAGES_PER_DEVICE=1000
# Máximo combinado de InboundSms + OutboundSms por modem_index (metade do limite por tipo).
SMS_MAX_MESSAGES_PER_MODEM=2000
# Mensagens apagadas por lote (evita transações longas no SQLite).
SMS_ROTATION_BATCH_SIZE=100
# Executar cleanup_sms_storage uma vez após migrate no arranque do contentor (docker/entrypoint.sh).
SMS_CLEANUP_ON_STARTUP=false

# =============================================================================
# 13. D-Bus system bus (docker/entrypoint.sh)
# =============================================================================
DBUS_SYSTEM_BUS_ADDRESS=unix:path=/run/dbus/system_bus_socket

# =============================================================================
# Opcional — superuser Django não é criado pelo entrypoint; usar manualmente:
#   docker compose ... exec hiwavetel python manage.py createsuperuser
# =============================================================================
