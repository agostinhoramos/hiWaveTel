# Copy to `.env` at the repository root (do not commit secrets).
# Template listing useful Docker ModemManager / Django variables only.

# --- Django (see config/settings/*.py) ---
# development = localhost-friendly defaults | production = DJANGO_SECRET_KEY + explicit hosts required
DJANGO_ENV=development
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Generate: python -c "from django.core.management.utils import get_random_secret_key as g; print(g())"
# DJANGO_SECRET_KEY=
HIWAVE_PORT=8000
# SQLite at project root on host (../db.sqlite3 → /app/host/db.sqlite3 in the container).
SQLITE_DB_PATH=/app/host/db.sqlite3

# --- Logging (file persistence; matches docs/logging-file-contract.md) ---
# Directory inside the container when using docker-compose volumes (default: /app/logs).
# Locally (pytest / manage.py) defaults to PROJECT_ROOT/logs when unset.
# DJANGO_LOG_DIR=/app/logs
# Filename only (joined with DJANGO_LOG_DIR); default hiwavetel-api.log.
# DJANGO_LOG_FILE=hiwavetel-api.log
# DEBUG, INFO, WARNING, ERROR, CRITICAL (default: INFO).
# APPLICATION_LOG_LEVEL=INFO

# --- Physical modem (entrypoint checklist before dbus/MM) ---
MODEM_TTY_PRIMARY=/dev/ttyUSB2
MODEM_TTY_SECONDARY=/dev/ttyUSB3
MODEM_LTE_INTERFACE=wwan0
MODEM_STRICT_WWAN_CHECK=false
# Seconds to wait for ModemManager to enumerate the modem (default tuned for faster feedback; push higher on slow hardware).
MODEM_ENUMERATION_WAIT_SEC=30
# Seconds to wait for enabled/registered state (avoids "modem not enabled yet").
MODEM_ENABLE_WAIT_SEC=20

# ModemManager startup: mmcli -S rescan retries (defaults: one scan, no idle wait between repeat scans).
# Set MMCLI_SCAN_TRIES above 1 only when cold-plug/USB needs rescans after ModemManager boots.
MMCLI_SCAN_TRIES=1
MMCLI_SCAN_SLEEP_SEC=1

# QMI/MBIM (e.g. EC25): on host `ls -l /dev/cdc-wdm*`; when present use e.g. MODEM_QMI_DEVICE=/dev/cdc-wdm0 in `.env`.
# If ModemManager logs QMI "no net port", `network_mode: host` and MODEM_QMI_DEVICE are defaults in docker/docker-compose.yml (see comments there).
# Omitting MODEM_QMI_DEVICE makes Compose map QMI as /dev/null between host and container.
# MODEM_QMI_DEVICE=/dev/cdc-wdm0

# ModemManager verbose (--debug) in container: true|false
MODEM_MANAGER_DEBUG=false

# SKIP_MODEM_HARDWARE_CHECK=1  # dev only: do not fail if TTY nodes are missing

# --- SIM ModemManager (optional unlock) ---
# Empty DEVICE_PIN_CODE => no mmcli --pin attempt (recommended if SIM is already unlocked).
DEVICE_PIN_CODE=
# Do not fix SIM_PATH to .../SIM/0 (indices vary); the entrypoint uses the SIM mmcli reports.
# Only needed for dual-SIM / override:
# SIM_PATH_OVERRIDES_MMCLI=true
# SIM_PATH=/org/freedesktop/ModemManager1/SIM/1

# --- Inbound SMS (optional second container process) ---
# Modem/N index for mmcli (-m); if AUTO_DETECT_MMCLI_INDEX=true the entrypoint aligns to the first enumerated modem.
AUTO_DETECT_MMCLI_INDEX=true
MODEM_MMCLI_INDEX=0
RUN_SMS_WATCHER=false

# Retry with backoff before giving up on initial snapshot (--messaging-list-sms) in watcher/sync.
# MMCLI_SNAPSHOT_TRIES=3
# MMCLI_SNAPSHOT_BACKOFF_SEC=1.25

# Optional mmcli -- exponential backoff when the failure looks transient (create/send).
# MMCLI_RETRY_MAX=3
# MMCLI_RETRY_BACKOFF_SEC=0.5

# HTTP probe `/api/health` timeout in seconds for mmcli inside it.
# HIWAVE_MMCLI_HEALTH_TIMEOUT=15

# --- External device gateway (MQTT prefix for device topics) ---
# Topic prefix for external devices: {prefix}/devices/{device_id}/sms/...
# MQTT_EXTERNAL_TOPIC_PREFIX=hidishelink_external

# --- Django module (rarely overridden) ---
# DJANGO_SETTINGS_MODULE=config.settings

